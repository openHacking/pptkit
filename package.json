{
  "name": "pptkit",
  "version": "0.1.0",
  "private": true,
  "description": "Monorepo workspace for the PPTKit presentation toolkit.",
  "packageManager": "pnpm@10.13.1",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "node ./scripts/dev.mjs",
    "build": "pnpm -r build",
    "lint": "node ./scripts/lint.mjs",
    "test": "pnpm -r test",
    "typecheck": "tsc -b --pretty false",
    "clean": "node ./scripts/clean.mjs"
  },
  "devDependencies": {
    "@types/node": "^24.3.0",
    "typescript": "^5.9.2"
  }
}
