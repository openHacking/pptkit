{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "types": ["vite/client"],
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/client/*"]
    },
    "sourceMap": true,
    "noEmit": true,
    "composite": true,
    "tsBuildInfoFile": "./tsconfig.app.tsbuildinfo"
  },
  "include": ["src/client/**/*.ts", "src/client/**/*.tsx", "vite.config.ts", "test/**/*.ts", "test/**/*.tsx"],
  "references": [
    { "path": "./tsconfig.server.json" },
    { "path": "../../packages/svg-renderer" }
  ]
}
