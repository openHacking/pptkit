{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "types": ["vite/client"],
    "noEmit": true,
    "composite": true,
    "tsBuildInfoFile": "./tsconfig.tsbuildinfo"
  },
  "include": ["src/**/*.ts", "vite.config.ts"],
  "references": [
    { "path": "../../packages/core" },
    { "path": "../../packages/pptx-exporter" },
    { "path": "../../packages/svg-renderer" },
    { "path": "../../packages/presentation-workflow" }
  ]
}
