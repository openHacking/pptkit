{
  "name": "@pptkit/core",
  "version": "0.1.6",
  "private": false,
  "type": "module",
  "description": "Authoring-facing document model for PPTKit.",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./browser": {
      "types": "./dist/index.d.ts",
      "default": "./dist/browser/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && node ../../scripts/build-browser-bundle.mjs @pptkit/core",
    "test": "pnpm run build && node --test test/*.test.mjs"
  }
}
