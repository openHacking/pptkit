{
  "name": "@pptkit/presentation-workflow",
  "version": "0.1.7",
  "private": false,
  "type": "module",
  "description": "Browser-neutral guided presentation workflow contracts and runtime for PPTKit.",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@pptkit/core": "workspace:*",
    "@xmldom/xmldom": "0.9.10",
    "fflate": "0.8.3"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "pnpm run build && node --test test/smoke.test.mjs"
  }
}
