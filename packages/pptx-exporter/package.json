{
  "name": "@pptkit/pptx-exporter",
  "version": "0.1.1",
  "private": false,
  "type": "module",
  "description": "PPTX export boundary for PPTKit.",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./node": {
      "types": "./dist/node.d.ts",
      "default": "./dist/node.js"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@pptkit/core": "workspace:*",
    "@pptkit/layout": "workspace:*",
    "fflate": "^0.8.3"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "pnpm run build && node --test test/*.test.mjs"
  }
}
